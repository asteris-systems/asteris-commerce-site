---
import Layout from '../layouts/Layout.astro';

const templates = [
  { name: 'Default', vertical: 'Generic starter', desc: 'Two-column buy-box, accordion details, related products. The safe choice for any store.' },
  { name: 'Atelier', vertical: 'Premium / accordion', desc: 'Dark accordion sections at the bottom hold spec-heavy content. Title in caps, generous whitespace.' },
  { name: 'Boutique', vertical: 'Fragrance / beauty', desc: 'Compact above-fold + accordion below. Refined typography, soft trust signals, loyalty banner slot.' },
  { name: 'Edge-to-edge', vertical: 'Editorial / full-bleed', desc: 'Image column extends to the screen edge. Sticky buy column. Best for hero-image-driven brands.' },
  { name: 'Editorial / Maker', vertical: 'Artisan / craft', desc: 'Dark hero with featured image, drop-cap body, pull-quote treatments. For story-led brands.' },
  { name: 'Gallery', vertical: 'Image-heavy / portfolio', desc: 'Featured image hero spans the page. Spec table, price + add-to-cart, then "About this piece" section.' },
  { name: 'Long-form', vertical: 'Story-led / DTC', desc: 'Dark immersive hero, sticky buy box on the right, full-bleed sections for sustainability, story, materials.' },
  { name: 'Shopify-clean', vertical: 'High conversion', desc: 'Two-column with sticky right rail. Trust badges. Variation form prominent. Inspired by Shopify Dawn.' },
  { name: 'Lookbook', vertical: 'Fashion / apparel', desc: 'Featured image + product gallery side-by-side hero. Sticky "Shop the look" upsell rail. Size guide CTA + accordion.' },
  { name: 'Specs', vertical: 'Tech / electronics', desc: 'Three-column with sticky spec rail. Key-features tile grid. Full-bleed "What\'s in the box" stripe. Datasheet slot.' },
  { name: 'Subscription-style', vertical: 'Food / supplements / beauty', desc: 'Subscription callout box where you write your actual process. Standard WC cart. Honest framing — no false toggle.' },
  { name: 'Configurator', vertical: 'Custom / made-to-order', desc: 'Sticky product gallery + build-time pill. Bordered "Customise yours" panel + add-ons. "Your total" subtotal card.' },
  { name: 'Wellness routine', vertical: 'Skincare / supplements', desc: 'Skin-type eyebrow above title. Key-ingredients hero. "How to use" routine block. Reviews-by-skin-type accordion.' },
  { name: 'B2B / Wholesale', vertical: 'Trade / industrial', desc: 'Trade-account badge. Monospace volume-pricing table. RFQ CTA box. MOQ inline with price. Spec sheet slot.' },
  { name: 'Tickets / Events', vertical: 'Conferences / workshops', desc: 'Dark event-hero card with date + venue. Sticky reserve panel with seat tiers + group-discount box. Speakers list.' },
];
---

<Layout
  title="Asteris. A free WordPress block theme for WooCommerce — 14 product page templates."
  description="Asteris is a free WordPress block theme built for WooCommerce. 14 product page templates covering ~85% of store verticals, native cart + checkout, per-product content fields, zero bundled JavaScript. Open source, GPL-2.0+."
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">★ Asteris — free theme</span>
      <h1>A free block theme with<br>14 product page templates.</h1>
      <p class="lead">No other free WooCommerce block theme ships this much. Pick a layout per product, fill the fields, ship. Zero bundled JavaScript, sub-50KB on the wire, GPL-2.0+ forever.</p>
      <div class="cta-row">
        <a href="/try-theme/" class="btn-primary">★ Try it live (in browser) →</a>
        <a href="#download" class="btn-secondary">Download v1.0.0</a>
        <a href="#templates" class="btn-secondary">See the templates</a>
      </div>
      <p class="hero-meta">v1.0.0 · Requires WP 6.7+ · PHP 8.1+ · WooCommerce optional</p>
    </div>
  </section>

  <section id="templates" class="templates">
    <div class="container">
      <h2 class="section-title">14 product page templates</h2>
      <p class="section-lead">Every template renders as standard WooCommerce blocks under the hood — your data stays portable. Pick a template per product from the editor's sidebar; switch any time without losing content.</p>
      <div class="tpl-grid">
        {templates.map(t => (
          <div class="tpl-card">
            <div class="tpl-vertical">{t.vertical}</div>
            <h3>{t.name}</h3>
            <p>{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="diff">
    <div class="container">
      <h2 class="section-title">What makes it different</h2>
      <div class="diff-grid">
        <div class="diff-card">
          <div class="diff-num">14</div>
          <h3>Product templates</h3>
          <p>Most free WC block themes ship one template. Twenty Twenty-Five ships zero WC-specific layouts. Storefront isn't a block theme. Asteris ships <strong>fourteen</strong>, each tuned for a real store vertical.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">18</div>
          <h3>Per-product content fields</h3>
          <p>Templates have bound slots for the things you actually change per product: BNPL line, loyalty banner, ingredients, spec table, size guide, build time. Edit from the WC product editor — no code.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">2</div>
          <h3>Cart + checkout templates</h3>
          <p>Branded cart and checkout that auto-apply via WC's stored page IDs — even if you rename the pages. Standard WC blocks inside, so any payment gateway you use just works.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">0kb</div>
          <h3>Bundled JavaScript</h3>
          <p>Theme files contain zero JS. Everything is server-rendered. Fast Core Web Vitals out of the box. The only JS your store loads is whatever WooCommerce ships — same as any block theme.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">100%</div>
          <h3>GPL-2.0+ forever</h3>
          <p>The theme is free, libre, and stays that way. No "Pro" version of the theme — paid extensions live as separate plugins (Pro Patterns, Pro Modules) that you can take or leave.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">4</div>
          <h3>Style variations</h3>
          <p>Switch the entire site palette + typography from the editor: Classic / Editorial / Minimal / Dark. Each ships ready-to-use without touching theme.json.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="fields">
    <div class="container">
      <h2 class="section-title">Per-product content fields</h2>
      <p class="section-lead">Templates use WordPress 6.5+ block bindings to pull text from per-product meta. You edit it in the WC product editor under a "Page Content" tab, grouped by template. Empty fields auto-hide.</p>
      <div class="field-grid">
        <div class="field-card">
          <h3>Shared</h3>
          <ul>
            <li>BNPL line + provider chips</li>
            <li>Loyalty banner</li>
            <li>Alternative-product line</li>
            <li>Bulk-enquiry line</li>
            <li>Shipping line</li>
          </ul>
        </div>
        <div class="field-card">
          <h3>Specs</h3>
          <ul>
            <li>Spec table</li>
            <li>Datasheet PDF link</li>
            <li>4 feature tiles</li>
            <li>What's in the box</li>
            <li>Compatibility</li>
            <li>Warranty</li>
          </ul>
        </div>
        <div class="field-card">
          <h3>Configurator</h3>
          <ul>
            <li>Build time pill</li>
            <li>Optional add-ons list</li>
            <li>Materials &amp; care</li>
          </ul>
        </div>
        <div class="field-card">
          <h3>Wellness</h3>
          <ul>
            <li>Skin/hair type tag</li>
            <li>Key ingredients hero</li>
            <li>How to use</li>
            <li>Reviews by skin type</li>
          </ul>
        </div>
        <div class="field-card">
          <h3>B2B</h3>
          <ul>
            <li>Trade-account badge</li>
            <li>Volume pricing table</li>
            <li>Minimum order quantity</li>
            <li>Request-for-quote CTA</li>
            <li>Spec sheet PDF</li>
            <li>Compliance notes</li>
          </ul>
        </div>
        <div class="field-card">
          <h3>Tickets</h3>
          <ul>
            <li>Date/time eyebrow</li>
            <li>Venue address</li>
            <li>Speakers list</li>
            <li>Seat tiers</li>
            <li>Group-discount box</li>
            <li>Refund policy</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="compat">
    <div class="container">
      <h2 class="section-title">Compatibility &amp; honest scope</h2>
      <ul class="inc-list">
        <li>Requires <strong>WordPress 6.7+</strong> and <strong>PHP 8.1+</strong></li>
        <li>WooCommerce is <strong>optional</strong> — non-WC sites get a clean blog/page theme</li>
        <li>WC product templates work with WC <strong>8.0+</strong> (uses canonical blockified-template attributes)</li>
        <li><strong>No payment plugin lock-in</strong> — uses standard WC cart/checkout blocks, so Stripe / PayPal / Square / any WC payment gateway works as-is</li>
        <li><strong>Subscription-style template is manual-fulfilment</strong> — the "Subscribe" framing is honest marketing for stores running email-based renewal. Real recurring billing needs WC Subscriptions or similar</li>
        <li><strong>B2B / Configurator pricing tiers are display-only</strong> — the volume-pricing table and add-on list are descriptive. Actual cart-side tiered pricing or add-on charges need a separate plugin</li>
        <li><strong>Tickets seat-tier UI is display-only</strong> — real seat reservation needs an events plugin (FooEvents, Event Tickets, etc.)</li>
        <li>No bundled fonts — uses system font stack for instant render. Bring your own via the editor if you want custom fonts</li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>How is this monetised if it's free?</h3>
          <p>The theme is free forever. Asteris is monetised through separate <strong>paid plugins</strong> — Pro Patterns (73 premium block patterns), Pro Modules (advanced features), and our hosted Cart product. The theme is the on-ramp. You can use it without ever buying anything.</p>
        </div>
        <div class="faq-item">
          <h3>What happens to my pages if I switch themes later?</h3>
          <p>Your content is portable because every template renders as standard WooCommerce + core Gutenberg blocks. Switch to any other block theme and your products keep their data — only the layout changes. The per-product field values stay in <code>postmeta</code> regardless of theme.</p>
        </div>
        <div class="faq-item">
          <h3>Can I edit the templates in the Site Editor?</h3>
          <p>Yes. Every template is editable via Appearance → Editor. The shipped versions are starting points; customise freely. Asteris ships with a <strong>round-trip canonicalizer</strong> built into our workflow so future updates won't blow away your customisations — only the file changes, your DB customisations stay.</p>
        </div>
        <div class="faq-item">
          <h3>Does it work with Elementor / Bricks / Divi?</h3>
          <p>The product templates are FSE block-theme templates — they don't compose with classic page-builder editors. If you're committed to a page builder, you're better off on a non-FSE theme. If you're new to block-theme editing (or willing to switch), Asteris is built for you.</p>
        </div>
        <div class="faq-item">
          <h3>Where do I report bugs or request features?</h3>
          <p>GitHub repo (link from the wp.org listing once we land). Email <strong><a href="mailto:support@asteriscommerce.com">support@asteriscommerce.com</a></strong>. We respond within 2 business days.</p>
        </div>
        <div class="faq-item">
          <h3>What's on the roadmap?</h3>
          <p>v1.1 adds 5 more product templates (Vinyl/Music, Plants/Garden, Kids/Toys, Books, Real Estate) plus animated style-variation switcher and richer empty-cart suggestions. See <a href="/roadmap/">the roadmap</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="download" class="final-cta">
    <div class="container">
      <h2>Get Asteris v1.0.0 — free</h2>
      <p>Download the theme ZIP, upload via Appearance → Themes → Add New, activate. Done.</p>
      <a href="https://releases.asteriscommerce.com/asteris-theme-latest.zip" class="btn-primary big">Download theme (.zip)</a>
      <p class="cta-meta">Also coming to <strong>wp.org</strong> — once we clear the directory review. GPL-2.0+ · No tracking · No phone-home</p>
    </div>
  </section>
</Layout>

<style>
  :root {
    --violet: #AA00FF;
    --violet-soft: rgba(170, 0, 255, 0.10);
    --violet-border: rgba(170, 0, 255, 0.32);
  }

  .container { max-width: 1120px; margin: 0 auto; padding: 0 32px; }

  .hero { padding: 96px 0 72px; }
  .eyebrow {
    display: inline-block; color: var(--violet); font-size: 15px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px;
  }
  h1 {
    font-size: 64px; font-weight: 700; letter-spacing: -0.02em; line-height: 1.05;
    margin: 0 0 20px; color: #0a0a0a;
  }
  .lead { font-size: 20px; line-height: 1.55; max-width: 760px; color: #4a5568; margin: 0 0 32px; }
  .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-meta { margin: 24px 0 0; font-size: 15px; color: #6b7280; letter-spacing: 0.03em; }

  .btn-primary {
    background: var(--violet); color: #fff; font-weight: 700; font-size: 17px;
    padding: 14px 28px; border-radius: 8px; text-decoration: none;
    transition: background 120ms, transform 100ms; display: inline-block;
  }
  .btn-primary:hover { background: #BD2FFF; transform: translateY(-1px); }
  .btn-primary.big { font-size: 18px; padding: 16px 36px; }
  .btn-secondary {
    background: transparent; color: #1a1a1a; font-weight: 600; font-size: 17px;
    padding: 14px 28px; border-radius: 8px; text-decoration: none;
    border: 1px solid #d8dce6;
  }
  .btn-secondary:hover { border-color: var(--violet); color: var(--violet); }

  .section-title { font-size: 32px; font-weight: 700; letter-spacing: -0.01em; margin: 0 0 16px; color: #0a0a0a; }
  .section-lead { font-size: 17px; color: #4a5568; max-width: 760px; margin: 0 0 40px; line-height: 1.6; }

  .templates { padding: 80px 0; background: #fafbfd; border-top: 1px solid #e0e3eb; border-bottom: 1px solid #e0e3eb; }
  .tpl-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }
  .tpl-card { background: #fff; border: 1px solid #e0e3eb; border-radius: 12px; padding: 24px; }
  .tpl-vertical { font-size: 13px; font-weight: 700; color: var(--violet); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
  .tpl-card h3 { font-size: 18px; font-weight: 700; margin: 0 0 10px; color: #0a0a0a; }
  .tpl-card p { font-size: 16px; line-height: 1.55; color: #4a5568; margin: 0; }

  .diff { padding: 80px 0; background: #fff; }
  .diff-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .diff-card { background: #fafbfd; border: 1px solid #e0e3eb; border-radius: 12px; padding: 28px; }
  .diff-num { font-size: 36px; font-weight: 700; color: var(--violet); line-height: 1; margin-bottom: 12px; }
  .diff-card h3 { font-size: 18px; font-weight: 700; margin: 0 0 10px; color: #0a0a0a; }
  .diff-card p { font-size: 16px; line-height: 1.6; color: #4a5568; margin: 0; }

  .fields { padding: 80px 0; background: #fafbfd; border-top: 1px solid #e0e3eb; border-bottom: 1px solid #e0e3eb; }
  .field-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; }
  .field-card { background: #fff; border: 1px solid #e0e3eb; border-radius: 10px; padding: 22px; }
  .field-card h3 { font-size: 15px; font-weight: 700; color: var(--violet); text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 14px; }
  .field-card ul { list-style: none; padding: 0; margin: 0; }
  .field-card li { font-size: 16px; line-height: 1.5; color: #1a1a1a; padding: 6px 0; border-bottom: 1px solid #f0f2f5; }
  .field-card li:last-child { border-bottom: none; }

  .compat { padding: 64px 0; background: #fff; border-bottom: 1px solid #e0e3eb; }
  .inc-list { list-style: none; padding: 0; margin: 0; max-width: 820px; }
  .inc-list li { padding: 12px 0 12px 28px; border-bottom: 1px solid #eef0f5; font-size: 17px; line-height: 1.55; color: #1a1a1a; position: relative; }
  .inc-list li:before { content: "✓"; position: absolute; left: 0; color: var(--violet); font-weight: 700; }
  .inc-list li:last-child { border-bottom: none; }

  .faq { padding: 80px 0; background: #fafbfd; border-top: 1px solid #e0e3eb; }
  .faq-grid { display: grid; gap: 18px; max-width: 880px; }
  .faq-item { background: #fff; border: 1px solid #e0e3eb; border-radius: 10px; padding: 22px 26px; }
  .faq-item h3 { font-size: 17px; font-weight: 700; margin: 0 0 10px; color: #0a0a0a; }
  .faq-item p { font-size: 17px; line-height: 1.6; color: #4a5568; margin: 0; }
  .faq-item code { background: #f4f5f7; padding: 2px 6px; border-radius: 4px; font-size: 15px; }
  .faq-item a { color: var(--violet); text-decoration: underline; }

  .final-cta { padding: 96px 0; text-align: center; background: #fff; }
  .final-cta h2 { font-size: 42px; font-weight: 700; margin: 0 0 12px; color: #0a0a0a; }
  .final-cta p { font-size: 17px; color: #4a5568; margin: 0 0 28px; }
  .cta-meta { margin-top: 22px; font-size: 15px; color: #6b7280; }
  .cta-meta strong { color: #1a1a1a; }

  @media (max-width: 768px) {
    h1 { font-size: 44px; }
    .lead { font-size: 18px; }
    .section-title { font-size: 26px; }
    .final-cta h2 { font-size: 30px; }
  }
</style>
