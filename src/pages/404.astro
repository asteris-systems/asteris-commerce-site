---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page not found · Asteris Commerce"
  description="The page you're looking for doesn't exist on asteriscommerce.com. You're probably looking for one of our two products: Asteris for WooCommerce or Asteris for WordPress."
>
  <section class="oops">
    <div class="container narrow">
      <div class="big">404</div>
      <h1>This page <span class="accent">doesn't exist.</span></h1>
      <p class="lead">
        You're on <strong>asteriscommerce.com</strong> — the parent brand. There are only a few pages here. If you were looking for product info, you probably want one of these:
      </p>

      <div class="cards">
        <a href="https://asterisforwoocommerce.com" class="card card--wc" target="_blank" rel="noopener">
          <div class="eyebrow">★ Asteris for WooCommerce</div>
          <h2>20-module WC plugin suite →</h2>
          <p>SEO, AI Suite, PDF Invoices, Variation Swatches, Wishlist, Side Cart, Coupons, Trust Badges and 12 more.</p>
        </a>
        <a href="https://asterisforwordpress.com" class="card card--wp" target="_blank" rel="noopener">
          <div class="eyebrow">★ Asteris for WordPress</div>
          <h2>11-module WP plugin suite →</h2>
          <p>Security + Login + 2FA, SEO + AI, Backups + Migration, SMTP + Email Logs and more.</p>
        </a>
      </div>

      <p class="links">
        Or maybe you were looking for: <a href="/">home</a> · <a href="/about">about</a> · <a href="/roadmap">roadmap</a> · <a href="/press">press</a> · <a href="mailto:founder@asteriscommerce.com">founder@asteriscommerce.com</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .oops {
    padding: 80px 0 100px;
    min-height: 60vh;
  }
  .narrow { max-width: 820px; }
  .big {
    font-family: var(--font-mono);
    font-size: 96px;
    font-weight: 900;
    color: var(--c-violet, #AA00FF);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -4px;
  }
  h1 {
    font-size: 56px;
    line-height: 1;
    letter-spacing: -2px;
    margin-bottom: 24px;
    color: var(--c-black);
  }
  .accent { color: var(--c-violet, #AA00FF); }
  .lead {
    font-size: 18px;
    line-height: 1.6;
    color: #333;
    margin-bottom: 36px;
    max-width: 680px;
  }
  .lead strong { color: var(--c-black); }
  @media (max-width: 700px) { .big { font-size: 64px; } h1 { font-size: 36px; } }

  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  @media (max-width: 700px) {
    .cards { grid-template-columns: 1fr; }
  }
  .card {
    background: var(--c-white);
    border: 2px solid var(--c-black);
    border-radius: var(--r-lg);
    border-top: 5px solid var(--tile, var(--c-black));
    padding: 22px;
    color: var(--c-text);
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    text-decoration: none;
  }
  .card--wc { --tile: #FF5B3F; }
  .card--wp { --tile: #3D5AFE; }
  .card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--tile);
  }
  .card .eyebrow {
    font-size: 12px;
    font-weight: 700;
    color: var(--tile);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }
  .card h2 {
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin-bottom: 10px;
    color: var(--c-black);
  }
  .card p {
    font-size: 14px;
    color: #555;
    line-height: 1.5;
    margin: 0;
  }

  .links {
    font-size: 14px;
    color: #555;
  }
  .links a {
    color: var(--c-violet, #AA00FF);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .links a:hover { color: var(--c-black); }
</style>
