---
import Layout from '../layouts/Layout.astro';

// Roadmap redesigned 6 Jun 2026: dropped the 3-column layout in favour of
// stacked product sections with brand-coloured top borders. Phase headings
// are anchor points down the scroll; modules use bold-name + em-dash pattern
// per Nick's preferred bullet style.
---

<Layout
  title="Roadmap. Asteris Commerce cross-product release timeline"
  description="Cross-product roadmap for Asteris for WooCommerce, Asteris for WordPress, and Asteris Cart. v1.0 ship status, v1.1+ planned modules, research-needed candidates. Honest about what's built vs what's banked."
>
  <section class="hero">
    <div class="container">
      <h1>Roadmap.</h1>
      <p class="lead">
        Cross-product release timeline across all three Asteris plugins. Honest about what's shipped, what's banked, and what's still under research. Dates are intentionally absent. See the <a href="https://asterisforwoocommerce.com/lifetime/" target="_blank" rel="noopener">no-hard-dates rule</a>.
      </p>
    </div>
  </section>

  <div class="legend-strip">
    <div class="container">
      <div class="legend-inner">
        <span class="legend-key"><span class="badge badge-shipped">SHIPPED</span></span>
        <span class="legend-key"><span class="badge badge-building">IN BUILD</span></span>
        <span class="legend-key"><span class="badge badge-planned">PLANNED</span></span>
        <span class="legend-key"><span class="badge badge-research">RESEARCH</span></span>
      </div>
    </div>
  </div>

  <section class="body">
    <div class="container">

      <!-- WC -->
      <section class="product product--wc">
        <div class="product-eyebrow">★ Asteris for WooCommerce</div>
        <h2 class="product-title">WC roadmap</h2>
        <p class="product-sub">20 modules shipped. Cookie Consent flagship in v1.1. Funnel Builder explicitly deferred.</p>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.0</h3>
            <span class="phase-label">shipped</span>
            <span class="badge badge-shipped">SHIPPED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">20 modules built and shipped at plugin v1.9.20</span></li>
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">AI Suite · SEO · PDF Invoices · Variation Swatches · Wishlist · Quote / Enquiry · Back in Stock · Side Cart · Sequential Order Numbers · Product Filtering · Min/Max Quantity · Asteris Links · Trust Badges · Free Shipping Bar · Stock Urgency · Delivery Timeline · Feature Labels · Product Badges · Analytics · Asteris Coupons</span></li>
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">6 of those modules in Asteris Free (WordPress.org)</span></li>
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">HPOS-verified · Block Cart compatible · 6-theme tested</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.1</h3>
            <span class="phase-label">first post-launch release</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Asteris Cookie Consent</strong> — GDPR, ePrivacy, CCPA, LGPD-compliant banner with real script-blocking. Hero feature of v1.1 release. Replaces CookieYes, Cookiebot, Iubenda ($79 to $348/yr SaaS each).</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Asteris Live Monitor</strong> — Real-time visitor dashboard built for stores. See who's on the site, what page they're on, what's in their cart, and which carts are about to abandon. Cart-aware from the ground up.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body">WordPress Multisite support</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body">WP-CLI commands (agency-scale operations)</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body">Customer self-service /account portal (licence management, downloads, invoices)</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body">Module 20 (Coupons) deferred features: AI-generated coupon copy, subscription-aware rules, stacking</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.2</h3>
            <span class="phase-label">second release</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Asteris Checkout Customizer</strong> — field-level checkout customisation (add/remove/reorder fields, conditional logic, custom thank-you pages). <em>Research-needed.</em></span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">Research</h3>
            <span class="phase-label">v1.2+ candidates</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Asteris Social Proof</strong> — recent-purchase and activity notifications. NotificationX, TrustPulse replacement. Honest-data-only positioning.</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Asteris Payment Icons</strong> — trust-signal payment-method icons at checkout, footer, or product page</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v2+</h3>
            <span class="phase-label">under consideration</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Asteris Funnel Builder</strong> — full CartFlows and FunnelKit replacement (multi-step funnel pages, one-click upsells, order bumps, A/B testing). <em>EXPLICITLY DEFERRED with documented blocking concerns. Revisit when there's evidence of customer demand and team capacity.</em></span></li>
          </ul>
        </div>
      </section>

      <!-- WP -->
      <section class="product product--wp">
        <div class="product-eyebrow">★ Asteris for WordPress</div>
        <h2 class="product-title">WP roadmap</h2>
        <p class="product-sub">11 modules in sequential build under the Module Quality Protocol. Security + Login + 2FA is the flagship wedge.</p>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.0</h3>
            <span class="phase-label">building (sequential ship)</span>
            <span class="badge badge-building">IN BUILD</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">Module Quality Protocol locked. Every module closes Tier 1 + Tier 2 gap analysis before the next module starts</span></li>
            <li class="module"><span class="module-icon icon-building">●</span><span class="module-body"><strong>Security + Login + 2FA</strong> — flagship wedge module. Built quality-first vs Wordfence Premium.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>SEO + AI</strong> — full SEO toolkit with AI-written meta. Shared with WC product.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Backups + Migration</strong> — scheduled, offsite, one-click restore.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>SMTP + Email Logs</strong> — major provider integrations, log table, deliverability alerts.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body">7 more modules planned for v1.0. See <a href="https://asterisforwordpress.com" target="_blank" rel="noopener">asterisforwordpress.com</a> for the full list</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.1+</h3>
            <span class="phase-label">banked</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">WordPress Multisite support</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">Performance + Image Optimisation</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">Activity Log</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">Code Snippets</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">Accessibility tooling</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">Forms</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.5+</h3>
            <span class="phase-label">deferred</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body">Custom Fields + Post Types (deferred past Feb 2027 ACF / SCF trial period)</span></li>
          </ul>
        </div>
      </section>

      <!-- Cart -->
      <section class="product product--cart">
        <div class="product-eyebrow">★ Asteris Cart</div>
        <h2 class="product-title">Cart roadmap</h2>
        <p class="product-sub">21 modules wired at alpha. v1.1 ships Recovery + Bot Filter as the flagship wedge.</p>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.0</h3>
            <span class="phase-label">alpha · pre-launch</span>
            <span class="badge badge-building">IN BUILD</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">21 modules built and wired at plugin v1.0.0-alpha.9</span></li>
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">Side Cart · Free Shipping Bar · Cart Page · Floating Button · Add-to-Cart Popup · Mobile Sticky Bar · Empty Cart · Shipping Calculator · Coupon URL · Sticky Checkout Button · Pixel Bridge · Trust Badges · Login · Thank-You Page · Express Checkout · GDPR Consent · Quote Mode · Multi-Step · Urgency Timer · Field Editor · Safe Mode</span></li>
            <li class="module"><span class="module-icon icon-shipped">✓</span><span class="module-body">HPOS code-verified · Block Cart compatible · Classic-hooks-first</span></li>
            <li class="module"><span class="module-icon icon-building">●</span><span class="module-body">End-to-end QA on real store + cross-theme verification (in progress)</span></li>
            <li class="module"><span class="module-icon icon-building">●</span><span class="module-body">Public launch: Founder Hundred to open launch. Velocity-decided window.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.1</h3>
            <span class="phase-label">first post-launch release</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Recovery + Bot Filter</strong> — abandoned-cart capture with IP fingerprinting, session validation, rate limiting. The flagship v1.1 wedge. Every competitor's recovery metric is bot-poisoned.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Sequence Runner</strong> — email recovery drips on WP Mail. Resend, Postmark integrations land later.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Exit-Intent Popup</strong> — last-chance offer before tab close, integrated with Recovery for opt-in capture.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Customer Portal</strong> — self-service licence management, downloads, invoices.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Multisite Support</strong> — network-activated mode for agency Multisite installs.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.2</h3>
            <span class="phase-label">upsell flow</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Order Bumps</strong> — pre-purchase upsell offers in the checkout summary.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Post-Purchase Upsells</strong> — one-click acceptance on the thank-you page using the original gateway token.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Downsells</strong> — alternate offer when an upsell is declined.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Coupon Bar</strong> — site-wide auto-applying promo bar with eligibility rules.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.3</h3>
            <span class="phase-label">UX polish</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Address Autocomplete</strong> — pluggable Google, Mapbox, Loqate, or OS Places backends. Merchant brings their own key. No Asteris-proxied billing.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Express Checkout v2</strong> — gateway-agnostic Payment Request API wrapper. Surfaces Stripe, WooPayments, Square, and Mollie native PRBs.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>WP-CLI Suite</strong> — agency-scale <code>wp asteris-cart</code> commands for bulk activation, module toggle, status export.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.4</h3>
            <span class="phase-label">analytics + growth (agency-tier)</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>A/B Testing</strong> — per-module variant testing with statistical significance gates. Surfaces results in admin.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Analytics Dashboard</strong> — unified revenue view. Which modules drove which conversions, attribution surviving custom URLs.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Cohort Reports</strong> — recovery cohort survival curves, urgency-timer effect on AOV, GDPR opt-in rates by region.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.5+</h3>
            <span class="phase-label">research-needed</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>AI Recovery Timing</strong> — optimal send-time per cohort. Honest-data-only. No fake ML claims. Must beat fixed-window baseline by N% in real tests.</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>SMS Recovery</strong> — Twilio, MessageBird send paths. Carrier compliance per market.</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Block Checkout Mode</strong> — full Asteris UX on WC's Block Checkout once WC core ships custom-step support. Currently classic-hooks-only by design.</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Agentic Hooks</strong> — MCP-style endpoints for AI assistants to manage cart/checkout config. Spec-pending.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v2+</h3>
            <span class="phase-label">under consideration</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Funnel Canvas</strong> — visual multi-page funnel builder. <em>EXPLICITLY DEFERRED. Only revisit when customer demand is documented and team capacity allows.</em></span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Agency Plus Tier</strong> — $799+ white-label option. Only ships if real demand surfaces (no white-label v1.0 through v1.5).</span></li>
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Multi-currency Switcher</strong> — if WC core doesn't ship it first. Currently under WC Roadmap consideration.</span></li>
          </ul>
        </div>
      </section>

      <!-- Asteris Platform — Partners Program -->
      <section class="product product--platform">
        <div class="product-eyebrow">★ Asteris Platform</div>
        <h2 class="product-title">Asteris Partners</h2>
        <p class="product-sub">Self-hosted partner program for the 4 Asteris plugins. Built on the existing licence server (pay.asteriscommerce.com). 25% Year 1 / 15% Year 2+ recurring commission, 60-day attribution cookie, cross-product attribution across all four plugins. <em>Not a customer-facing module — this is Asteris's own program. The separate Asteris Affiliate WC module (for customers to run their own affiliate programs) is listed under Research below.</em></p>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.0</h3>
            <span class="phase-label">ships with launch</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Asteris Partners</strong> — public application page, partner dashboard, click + conversion tracking, refund-aware payouts via Stripe Connect, cross-product attribution across all 3 Asteris plugins within a 60-day window.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Founding Partners</strong> — 25 launch slots (matches Year 1 commission %). Top 10 invited from organic advocates pre-launch; other 15 open via public application at launch month. Locked 30% lifetime commission + early access + private Slack + co-marketing.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Tax compliance built in</strong> — W-9 / W-8BEN / ABN collection at signup. Auto-1099-NEC reporting at the $600 US threshold. Built so agencies don't have to handle it themselves.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Anti-fraud baseline</strong> — self-referral blocking, velocity caps, refund-rate flagging. Optional AI fraud detection via the Asteris AI Suite hook in v1.2.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">v1.1</h3>
            <span class="phase-label">Asteris stack integrations</span>
            <span class="badge badge-planned">PLANNED</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Asteris Cart funnel integration</strong> — partners can build custom-branded checkout funnels via Asteris Cart. Unique URL per partner, custom messaging, custom thank-you page.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Live Monitor signals for partners</strong> — partners see THEIR referred visitors live. "Your visitor just added $200, idle 5min" — partners can intervene to close the sale.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>AI Suite marketing copy</strong> — one-click "generate email / tweet / blog angle" for the product they're promoting. BYO API key.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Embed-anywhere widgets</strong> — JS snippet that renders live product cards with the partner's link baked in. Built for content partners running review blogs.</span></li>
            <li class="module"><span class="module-icon icon-planned">●</span><span class="module-body"><strong>Reverse-partner at thank-you</strong> — paying customers invited to join Partners in one click. Conversion lift on dormant referral capacity.</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-head">
            <h3 class="phase-version">Research</h3>
            <span class="phase-label">downstream</span>
            <span class="badge badge-research">RESEARCH</span>
          </div>
          <ul class="modules">
            <li class="module"><span class="module-icon icon-research">◯</span><span class="module-body"><strong>Asteris Affiliate WC module</strong> — a separate customer-facing WC plugin that replaces AffiliateWP / SliceWP / Solid Affiliate for WC store owners running their own affiliate program. Target v1.2+ on the WC roadmap. Gap analysis underway.</span></li>
          </ul>
        </div>
      </section>

    </div>
  </section>
</Layout>

<style>
  .hero { padding: 80px 0 32px; }
  h1 {
    font-size: 64px;
    line-height: 1;
    letter-spacing: -2px;
    margin: 0 0 24px;
  }
  .lead {
    font-size: 22px;
    color: var(--c-muted);
    margin: 0;
  }
  @media (max-width: 700px) { h1 { font-size: 44px; } .lead { font-size: 18px; } }

  /* Legend strip */
  .legend-strip {
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    padding: 18px 0;
    margin: 24px 0 56px;
  }
  .legend-inner {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    align-items: center;
    font-size: 16px;
    color: var(--c-muted);
  }
  .legend-key {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
  }
  .badge {
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 13px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }
  .badge-shipped  { background: rgba(0,200,83,0.12);  color: #0c8540; }
  .badge-building { background: rgba(255,91,63,0.12); color: #c8431d; }
  .badge-planned  { background: rgba(170,0,255,0.10); color: #7400b3; }
  .badge-research { background: rgba(0,0,0,0.06);     color: var(--c-muted); }

  /* Body */
  .body { padding: 0 0 80px; }

  /* Product sections */
  .product {
    background: var(--c-white);
    border-radius: 16px;
    border: 1px solid var(--c-border);
    padding: 48px 56px;
    margin-bottom: 48px;
    border-top: 6px solid var(--c-orange);
    position: relative;
    overflow: hidden;
  }
  .product--wc       { border-top-color: #FF5B3F; }
  .product--wp       { border-top-color: #3D5AFE; }
  .product--cart     { border-top-color: #00C853; }
  .product--platform { border-top-color: #AA00FF; }

  .product-eyebrow {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    display: inline-block;
  }
  .product--wc       .product-eyebrow { color: #FF5B3F; }
  .product--wp       .product-eyebrow { color: #3D5AFE; }
  .product--cart     .product-eyebrow { color: #00C853; }
  .product--platform .product-eyebrow { color: #AA00FF; }

  .product-title {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -1px;
    margin: 0 0 8px;
    line-height: 1.1;
  }
  .product-sub {
    font-size: 18px;
    color: var(--c-muted);
    margin: 0 0 36px;
  }

  /* Phase = one version block within a product */
  .phase {
    padding: 28px 0;
    border-top: 1px solid var(--c-border);
  }
  .phase:first-of-type { border-top: none; padding-top: 0; }
  .phase-head {
    display: flex;
    align-items: center;
