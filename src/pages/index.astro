---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Asteris Commerce — the free WordPress + WooCommerce block theme. From a Sydney team."
  description="Free WordPress + WooCommerce block theme with 14 product page templates. Plus four plugin suites for WP + WC. Sydney-built. One vendor."
>

  <!-- ── Hero ────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="eyebrow">★ Australian indie WP + WC vendor</div>
      <h1>
        The free block theme<br />
        for <span class="accent-wp">WordPress</span> and <span class="accent-wc">WooCommerce</span>.
      </h1>
      <p class="lead">
        Fast on the wire. Zero bundled JavaScript. <strong>14 product page templates</strong> when you add WooCommerce.
      </p>
      <p class="lead">
        Use Asteris on any WordPress site — blogs, portfolios, business sites, full WooCommerce stores. Sub-50KB on the wire, sleek out of the box, four built-in style variations. Then add the plugin suite that matches: SEO, security, performance, swatches, PDF invoices, checkout funnel, affiliate program. All from one Sydney team.
      </p>
      <div class="hero-cta-row">
        <a href="/asteris-theme/" class="btn-hero btn-hero-primary">Get the free theme →</a>
        <a href="#plugins" class="btn-hero btn-hero-secondary">See the plugin suites</a>
      </div>
      <p class="no-vc">No VC. No marketing team. No growth hacker, by design.</p>
    </div>
  </section>

  <!-- ── Theme spotlight ──────────────────────────────────────────────── -->
  <section id="theme" class="spotlight">
    <div class="container">
      <div class="spot-card">
        <div class="spot-meta">
          <span class="spot-eyebrow">★ Start free</span>
          <span class="spot-status">v1.0.0 · Live</span>
        </div>
        <h2 class="spot-h">Asteris Theme. The free WordPress + WooCommerce block theme.</h2>
        <p class="spot-desc">
          A block theme that's fast, sleek, and stays out of your way. On a WordPress site, it ships four style variations (Classic / Editorial / Minimal / Dark) and a system font stack for instant render. Add WooCommerce and you unlock <strong>14 product page templates</strong> (Default, Atelier, Boutique, Edge-to-edge, Editorial, Gallery, Long-form, Shopify-clean, Lookbook, Specs, Subscription-style, Configurator, Wellness, B2B/Wholesale, Tickets) plus branded cart and checkout — all auto-applied. <strong>18 per-product content fields</strong> are bound to product meta, so merchants edit them from the WooCommerce product editor.
        </p>
        <div class="spot-bullets">
          <div class="spot-bullet"><strong>0 KB</strong><span>bundled JavaScript</span></div>
          <div class="spot-bullet"><strong>14</strong><span>product templates</span></div>
          <div class="spot-bullet"><strong>4</strong><span>style variations</span></div>
          <div class="spot-bullet"><strong>GPL-2.0+</strong><span>forever</span></div>
        </div>
        <a href="/asteris-theme/" class="btn-hero btn-hero-primary spot-cta">Read more about the theme →</a>
      </div>
    </div>
  </section>

  <!-- ── Plugin suites — 2×2 grid ───────────────────────────────────── -->
  <section id="plugins" class="plugins">
    <div class="container">
      <div class="section-head">
        <h2 class="section-h">Four plugin suites — under one vendor.</h2>
        <p class="section-lead">
          Each plugin replaces a stack of separate licences. Each is built to the same Module Quality Protocol. All four are sold direct — no marketplaces, no resellers, no surprise upgrade gates.
        </p>
      </div>

      <div class="plugin-grid">
        <a href="https://asterisforwordpress.com" class="plug plug--wp" target="_blank" rel="noopener">
          <div class="plug-head">
            <div class="plug-eye"><span class="ps">★</span> Asteris for WordPress</div>
            <span class="plug-stat plug-stat--live">Live · v1.0</span>
          </div>
          <h3>11 modules. For any WordPress site.</h3>
          <ul>
            <li><strong>Security + 2FA</strong> · SEO + AI · Performance · Forms</li>
            <li>SMTP · Activity Log · Analytics + Pixels · Image Optimization</li>
            <li>Backups + Migration · Code Snippets · WCAG accessibility scanner</li>
            <li>Replaces <strong>~$1,100/yr</strong> of separate plugin licences</li>
          </ul>
          <span class="plug-cta">asterisforwordpress.com →</span>
        </a>

        <a href="https://asterisforwoocommerce.com" class="plug plug--wc" target="_blank" rel="noopener">
          <div class="plug-head">
            <div class="plug-eye"><span class="ps">★</span> Asteris for WooCommerce</div>
            <span class="plug-stat plug-stat--live">Live · v1.0</span>
          </div>
          <h3>20 modules. For every WooCommerce store.</h3>
          <ul>
            <li><strong>SEO</strong> · PDF Invoices · <strong>Variation Swatches</strong> · Wishlist</li>
            <li>Quote/Enquiry · Back in Stock · Side Cart · Sequential Order Numbers</li>
            <li>Filters · Min/Max Qty · Links · Trust Badges · Free Shipping Bar</li>
            <li>Replaces <strong>~$1,650/yr</strong> of separate plugin licences</li>
          </ul>
          <span class="plug-cta">asterisforwoocommerce.com →</span>
        </a>

        <a href="https://asteriscart.com" class="plug plug--cart" target="_blank" rel="noopener">
          <div class="plug-head">
            <div class="plug-eye"><span class="ps">★</span> Asteris Cart</div>
            <span class="plug-stat plug-stat--live">Live · v1.0</span>
          </div>
          <h3>21 modules. For the WooCommerce checkout funnel.</h3>
          <ul>
            <li>Side cart · free shipping bar · <strong>multi-step checkout</strong></li>
            <li>Urgency timer · trust badges · GDPR consent · express checkout</li>
            <li>Quote mode · order bumps · post-purchase upsells</li>
            <li>Replaces <strong>~$540/yr</strong> of CartFlows + FunnelKit + CheckoutWC</li>
          </ul>
          <span class="plug-cta">asteriscart.com →</span>
        </a>

        <a href="https://asterisaffiliates.com" class="plug plug--aff" target="_blank" rel="noopener">
          <div class="plug-head">
            <div class="plug-eye"><span class="ps">★</span> Asteris Affiliates</div>
            <span class="plug-stat plug-stat--live">Live · v1.0</span>
          </div>
          <h3>A full affiliate program. WP + WC. Self-hosted.</h3>
          <ul>
            <li><strong>Multi-tier commissions</strong> · recurring renewals · 3 payout methods</li>
            <li>Stripe Connect · PayPal · encrypted bank transfer</li>
            <li>15 email templates · refund-rate auto-suspend · vanity landing pages</li>
            <li>Replaces <strong>$300–$2,400/yr</strong> of AffiliateWP / Tapfiliate / Refersion</li>
          </ul>
          <span class="plug-cta">asterisaffiliates.com →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Round it out — Blocks + Pro Patterns ──────────────────────── -->
  <section class="roundout">
    <div class="container">
      <div class="section-head">
        <h2 class="section-h">Round it out.</h2>
        <p class="section-lead">
          Two add-on toolkits that compose with everything above. Use either or both.
        </p>
      </div>

      <div class="ro-grid">
        <a href="https://asterisblocks.com" class="ro-card ro-card--blocks" target="_blank" rel="noopener">
          <div class="ro-head">
            <div class="ro-eye"><span class="ps">★</span> Asteris Blocks</div>
            <span class="ro-stat ro-stat--free">Free · wp.org</span>
          </div>
          <h3>50 Gutenberg blocks. No upsells.</h3>
          <p>
            Hero, Pricing Table, FAQ with schema, Recipe Card, Countdown, Code Block, Image Hotspots, Map, QR Code, Before/After Slider, Table of Contents — and 39 more. Newsletter optin with Mailchimp / MailerLite / ConvertKit / Brevo adapters. <strong>No Pro tier, ever.</strong>
          </p>
          <span class="ro-cta">asterisblocks.com →</span>
        </a>

        <a href="/asteris-pro-patterns/" class="ro-card ro-card--patterns">
          <div class="ro-head">
            <div class="ro-eye"><span class="ps">★</span> Asteris Pro Patterns</div>
            <span class="ro-stat ro-stat--paid">Paid · from $49/yr</span>
          </div>
          <h3>73 premium block patterns.</h3>
          <p>
            Niche page templates, multimedia sections, audio/video blocks, premium e-commerce patterns, heroes, and composite sections. Drop them onto any page, replace the placeholder content, ship. <strong>Founder pricing locked for life</strong> on the first 100 customers.
          </p>
          <span class="ro-cta">Read more about Pro Patterns →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Mission strip · "Less cost, more inclusions" ─────────────── -->
  <section class="mission-strip">
    <div class="container">
      <div class="mission-grid">
        <div class="mission-headline">
          <div class="mission-eyebrow">Our mission</div>
          <h2 class="mission-h">More inclusions. Less cost. Australian-built.</h2>
          <p class="mission-lead">
            One vendor relationship replaces stacks of paid plugins. Across the six products, we replace
            <strong>~$5,960/yr</strong> of competing tools for <strong>~$600–$2,000/yr</strong>.
            We're honest about what's in each plugin and what's not — no "Pro tier" surprises mid-trial.
          </p>
        </div>
        <div class="mission-table">
          <div class="mission-row mission-row--head"><span>Product</span><span>Replaces</span><span>Asteris price</span></div>
          <div class="mission-row"><span><strong>Asteris Theme</strong></span><span>~$59/yr theme + WC patches</span><span><strong>Free forever</strong></span></div>
          <div class="mission-row"><span><strong>Asteris for WP</strong></span><span>~$1,100/yr</span><span>$149–$549/yr</span></div>
          <div class="mission-row"><span><strong>Asteris for WC</strong></span><span>~$1,650/yr</span><span>$149–$549/yr</span></div>
          <div class="mission-row"><span><strong>Asteris Cart</strong></span><span>~$540/yr</span><span>$99–$399/yr</span></div>
          <div class="mission-row"><span><strong>Asteris Affiliates</strong></span><span>$300–$2,400/yr</span><span>$149–$549/yr</span></div>
          <div class="mission-row"><span><strong>Asteris Blocks</strong></span><span>~$400/yr</span><span><strong>Free forever</strong></span></div>
          <div class="mission-row mission-row--total"><span><strong>Full stack</strong></span><span><strong>~$5,960/yr</strong></span><span><strong>~$600–$2,000/yr</strong></span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Why six products ────────────────────────────────────────────── -->
  <section class="why">
    <div class="container">
      <div class="why-inner">
        <h2>Why six products, one company.</h2>
        <p>
          Most WordPress sites don't run WooCommerce. Most WooCommerce stores have plugin needs that go beyond what a generic WP plugin covers. And the WooCommerce checkout has its own deep stack of category-specific plugins (cart drawer, urgency, multi-step, express, GDPR) that don't belong inside a general-purpose WC suite.
        </p>
        <p>
          The free <strong>Asteris Theme</strong> is the on-ramp — install it on any WP site. <strong>Asteris for WordPress</strong> covers what any WP site needs (security, SEO, backups, email). <strong>Asteris for WooCommerce</strong> covers what a WC store specifically needs (product page, conversion, fulfilment). <strong>Asteris Cart</strong> covers the checkout funnel itself. <strong>Asteris Affiliates</strong> turns customers into a sales channel. <strong>Asteris Blocks + Pro Patterns</strong> round out content design.
        </p>
        <p>
          Some modules genuinely overlap — SEO + AI, Analytics, Links, AI library, Activity Log. Those are built once and vendored across all four plugins, so the same code ships everywhere. Most modules don't overlap, which is why they're separate plugins instead of one mega-plugin nobody asked for.
        </p>
        <p>
          One company means one vendor relationship, one support inbox, one philosophy. Six products means each one stays focused on its actual buyer.
        </p>
      </div>
    </div>
  </section>

  <!-- ── About strip ─────────────────────────────────────────────────── -->
  <section class="about-strip">
    <div class="container">
      <div class="about-inner">
        <div class="about-text">
          <h3>About the company</h3>
          <p>
            Asteris Commerce is the products division of My Cosmic Message Pty Ltd, an Australian proprietary limited company (ACN 652 358 159, ABN 30 652 358 159) incorporated in 2021. Sole director Nick Lord, based in Sydney. The same Pty Ltd has been operating Orion Web Service (full-stack WP and WC development and hosting) since 2021. Asteris was built from five years of patterns observed running real client stores. No VC. No outside funding. No growth hacker. Funded by Orion Web Service revenue, plus Founder-tier subscriptions during launch, plus standing subscriptions thereafter.
          </p>
          <a href="/about" class="btn btn-large">Read more →</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────── */
  .hero { padding: 70px 0 50px; }
  .eyebrow {
    display: inline-block;
    background: var(--c-yellow);
    padding: 4px 12px;
    border-radius: var(--r-sm);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
    margin-bottom: 24px;
    color: var(--c-black);
  }
  h1 {
    font-size: 76px;
    line-height: 1.0;
    letter-spacing: -2.5px;
    margin-bottom: 26px;
    font-weight: 900;
  }
  h1 .accent-wp { color: #3D5AFE; }
  h1 .accent-wc { color: #FF5B3F; }
  .lead { font-size: 21px; color: #333; line-height: 1.55; margin-bottom: 14px; max-width: 880px; }
  .lead strong { color: var(--c-black); }
  .hero-cta-row { display: flex; gap: 14px; flex-wrap: wrap; margin: 28px 0 22px; }
  .btn-hero {
    display: inline-block;
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid var(--c-black);
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    white-space: nowrap;
  }
  .btn-hero-primary {
    background: var(--c-violet, #AA00FF);
    color: #fff;
    border-color: var(--c-violet, #AA00FF);
    box-shadow: 4px 4px 0 var(--c-black);
  }
  .btn-hero-primary:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--c-black);
  }
  .btn-hero-secondary {
    background: #fff;
    color: var(--c-black);
    box-shadow: 4px 4px 0 var(--c-black);
  }
  .btn-hero-secondary:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--c-violet, #AA00FF);
    color: var(--c-violet, #AA00FF);
  }
  .no-vc { font-size: 16px; color: var(--c-muted); font-style: italic; margin-top: 10px; }
  @media (max-width: 700px) {
    h1 { font-size: 44px; letter-spacing: -1.5px; }
    .lead { font-size: 17px; }
  }

  /* ── Section heads ─────────────────────────────────────────────── */
  .section-head { margin-bottom: 38px; max-width: 880px; }
  .section-h {
    font-size: 38px;
    line-height: 1.1;
    letter-spacing: -1.4px;
    margin: 0 0 14px;
    font-weight: 900;
    color: var(--c-black);
  }
  .section-lead { font-size: 18px; line-height: 1.55; color: #444; margin: 0; }
  @media (max-width: 700px) { .section-h { font-size: 28px; letter-spacing: -1px; } .section-lead { font-size: 16px; } }

  /* ── Theme spotlight ───────────────────────────────────────────── */
  .spotlight { padding: 30px 0 60px; }
  .spot-card {
    background: linear-gradient(135deg, #f7f5ff 0%, #fff 60%);
    border: 2px solid var(--c-black);
    border-top: 6px solid var(--c-violet, #AA00FF);
    border-radius: var(--r-lg);
    padding: 40px 44px;
    box-shadow: 8px 8px 0 var(--c-violet, #AA00FF);
  }
  .spot-meta { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
  .spot-eyebrow {
    font-size: 14px; font-weight: 700; color: var(--c-violet, #AA00FF);
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .spot-status {
    font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px;
    padding: 4px 12px; border-radius: 999px; background: #06D6A0; color: #fff;
  }
  .spot-h { font-size: 36px; line-height: 1.15; letter-spacing: -1.2px; margin: 0 0 18px; font-weight: 900; color: var(--c-black); }
  .spot-desc { font-size: 18px; line-height: 1.6; color: #333; margin: 0 0 26px; }
  .spot-desc strong { color: var(--c-black); }
  .spot-bullets { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
  .spot-bullet {
    background: #fff; border: 1px solid #e0e3eb; border-radius: 10px;
    padding: 16px; text-align: center;
  }
  .spot-bullet strong {
    display: block; font-size: 26px; font-weight: 900; color: var(--c-violet, #AA00FF);
    line-height: 1; margin-bottom: 4px;
  }
  .spot-bullet span { font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }
  .spot-cta { margin-top: 4px; }
  @media (max-width: 720px) {
    .spot-card { padding: 28px 22px; box-shadow: 5px 5px 0 var(--c-violet, #AA00FF); }
    .spot-h { font-size: 26px; letter-spacing: -0.8px; }
    .spot-desc { font-size: 16px; }
    .spot-bullets { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Plugin grid 2×2 ─────────────────────────────────────────── */
  .plugins { padding: 60px 0; }
  .plugin-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .plug {
    background: #fff;
    border: 2px solid var(--c-black);
    border-top: 6px solid var(--c, var(--c-violet, #AA00FF));
    border-radius: var(--r-lg);
    padding: 26px 28px;
    color: var(--c-text);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }
  .plug:hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--c);
  }
  .plug--wp { --c: #3D5AFE; }
  .plug--wc { --c: #FF5B3F; }
  .plug--cart { --c: #00C853; }
  .plug--aff { --c: #06D6A0; border-color: #06D6A0; }
  .plug-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
  .plug-eye {
    font-size: 13px; font-weight: 700; color: var(--c);
    text-transform: uppercase; letter-spacing: 0.5px;
    display: flex; align-items: center; gap: 7px;
  }
  .plug-eye .ps { font-size: 18px; color: var(--c); line-height: 1; }
  .plug-stat {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    padding: 3px 10px; border-radius: 999px; border: 1.5px solid currentColor;
    background: rgba(255,255,255,0.9); white-space: nowrap;
  }
  .plug-stat--live { color: #2e7d32; }
  .plug-stat--dev { color: #c0392b; }
  .plug-stat--planned { color: #888; }
  .plug h3 {
    font-size: 22px; line-height: 1.2; letter-spacing: -0.6px;
    margin: 0 0 14px; font-weight: 900; color: var(--c-black);
  }
  .plug ul { list-style: none; padding: 0; margin: 0 0 18px; }
  .plug li {
    font-size: 14px; line-height: 1.55; color: #444;
    padding: 5px 0 5px 18px; position: relative;
  }
  .plug li::before { content: '✓'; position: absolute; left: 0; color: var(--c); font-weight: 800; }
  .plug li strong { color: var(--c-black); }
  .plug-cta { margin-top: auto; font-weight: 700; color: var(--c); font-size: 15px; }
  @media (max-width: 800px) { .plugin-grid { grid-template-columns: 1fr; } }

  /* ── Round-it-out ───────────────────────────────────────────────── */
  .roundout { padding: 60px 0 80px; background: #fafbfd; border-top: 1px solid #e0e3eb; border-bottom: 1px solid #e0e3eb; }
  .ro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .ro-card {
    background: #fff;
    border: 2px solid var(--c-black);
    border-top: 6px solid var(--c, #FFC107);
    border-radius: var(--r-lg);
    padding: 26px 28px;
    color: var(--c-text);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }
  .ro-card:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0 var(--c); }
  .ro-card--blocks { --c: #FFC107; border-color: #FFC107; }
  .ro-card--patterns { --c: #AA00FF; border-color: #AA00FF; }
  .ro-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
  .ro-eye {
    font-size: 13px; font-weight: 700; color: var(--c);
    text-transform: uppercase; letter-spacing: 0.5px;
    display: flex; align-items: center; gap: 7px;
  }
  .ro-eye .ps { font-size: 18px; color: var(--c); line-height: 1; }
  .ro-stat {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    padding: 3px 10px; border-radius: 999px; white-space: nowrap;
  }
  .ro-stat--free { background: #FFC107; color: #0a0a0a; }
  .ro-stat--paid { background: #AA00FF; color: #fff; }
  .ro-card h3 {
    font-size: 22px; line-height: 1.2; letter-spacing: -0.6px;
    margin: 0 0 14px; font-weight: 900; color: var(--c-black);
  }
  .ro-card p { font-size: 15px; line-height: 1.6; color: #444; margin: 0 0 18px; }
  .ro-card p strong { color: var(--c-black); }
  .ro-cta { margin-top: auto; font-weight: 700; color: var(--c); font-size: 15px; }
  @media (max-width: 800px) { .ro-grid { grid-template-columns: 1fr; } }

  /* ── Mission strip (kept from previous) ─────────────────────────── */
  .mission-strip {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
    color: #fff;
    padding: 70px 0;
    border-top: 6px solid #AA00FF;
  }
  .mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
  .mission-eyebrow {
    display: inline-block; background: #AA00FF; color: #fff;
    padding: 4px 12px; border-radius: 4px;
    font-size: 11px; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; margin-bottom: 18px;
  }
  .mission-h { font-size: 42px; line-height: 1.05; letter-spacing: -1.5px; margin: 0 0 18px; color: #fff; }
  .mission-lead { font-size: 16px; line-height: 1.55; color: #d4d4d4; margin: 0; }
  .mission-lead strong { color: #06D6A0; }
  .mission-table {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 6px 0;
  }
  .mission-row {
    display: grid; grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: 12px; padding: 12px 20px; font-size: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .mission-row:last-child { border-bottom: 0; }
