---
const year = 2026;
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="col col-brand">
      <a href="/" class="brand" aria-label="Asteris Commerce home"><span class="star">★</span> Asteris Commerce</a>
      <p class="tagline">Faster sites. Lower memory. Smaller install. Three plugins from one Sydney team.</p>
      <p class="aus">Made in Australia · ABN 30 652 358 159</p>
    </div>
    <div class="col">
      <h4>Products</h4>
      <a href="https://asterisforwoocommerce.com" target="_blank" rel="noopener">Asteris for WooCommerce</a>
      <a href="https://asterisforwordpress.com" target="_blank" rel="noopener">Asteris for WordPress</a>
      <a href="https://asteriscart.com" target="_blank" rel="noopener">Asteris Cart</a>
    </div>
    <div class="col">
      <h4>Company</h4>
      <a href="/about">About</a>
      <a href="/roadmap">Roadmap</a>
      <a href="/press">Press</a>
    </div>
    <div class="col">
      <h4>Contact</h4>
      <a href="mailto:founder@asteriscommerce.com">founder@asteriscommerce.com</a>
    </div>
  </div>
  <div class="legal-strip">
    <p>© {year} My Cosmic Message Pty Ltd t/a Asteris Commerce. All rights reserved.</p>
    <p class="meta">WordPress is a registered trademark of the WordPress Foundation. WooCommerce is a trademark of Automattic Inc. Asteris Commerce is not affiliated with either.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-black);
    color: #cccccc;
    padding: 64px var(--gutter) 32px;
    margin-top: 80px;
  }
  .footer-grid {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 36px;
    padding-bottom: 48px;
  }
  .col h4 {
    color: var(--c-white);
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 14px;
  }
  .col a {
    display: block;
    color: #999999;
    font-size: 15px;
    padding: 5px 0;
  }
  .col a:hover { color: var(--c-orange); }
  .col-brand a.brand {
    font-size: 24px;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 12px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }
  .col-brand a.brand:hover { color: var(--c-orange); }
  .col-brand a.brand .star {
    color: var(--c-orange);
    font-size: 28px;
  }
  .tagline {
    color: #aaaaaa;
    font-size: 16px;
    margin-bottom: 10px;
    line-height: 1.55;
  }
  .aus {
    color: #777777;
    font-size: 13px;
    white-space: nowrap;
  }
  .legal-strip {
    max-width: var(--max-w);
    margin: 0 auto;
    border-top: 1px solid #222222;
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13px;
    color: #777777;
  }
  .legal-strip .meta {
    color: #555555;
    max-width: 580px;
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 500px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
