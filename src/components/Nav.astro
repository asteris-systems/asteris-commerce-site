---
interface Props {
  currentPath?: string;
}
const { currentPath = '' } = Astro.props;

const navLinks = [
  { href: '/asteris-theme/',         label: 'Asteris Theme', match: '/asteris-theme' },
];

const pluginItems = [
  { href: 'https://asterisforwordpress.com',   label: 'For WordPress',   color: '#3D5AFE', desc: '11 modules · security · SEO · performance · forms · backups' },
  { href: 'https://asterisforwoocommerce.com', label: 'For WooCommerce', color: '#FF5B3F', desc: '20 modules · SEO · swatches · PDF invoices · wishlist · filters' },
  { href: 'https://asteriscart.com',           label: 'Asteris Cart',    color: '#00C853', desc: '21 modules · side cart · checkout funnel · urgency · upsells' },
  { href: 'https://asterisaffiliates.com',     label: 'Asteris Affiliates', color: '#06D6A0', desc: 'Full affiliate program · 3 payout methods · self-hosted' },
];

const tailLinks = [
  { href: '/asteris-pro-patterns/', label: 'Patterns', match: '/asteris-pro-patterns' },
  { href: 'https://asterisblocks.com', label: 'Blocks', external: true },
  { href: '/about',                  label: 'About',    match: '/about' },
  { href: '/roadmap',                label: 'Roadmap',  match: '/roadmap' },
  { href: '/press',                  label: 'Press',    match: '/press' },
];
---

<div class="site-nav-wrap">
  <nav class="site-nav" aria-label="Main">
    <a href="/" class="logo" aria-label="Asteris Commerce home">
      <span class="star" aria-hidden="true">★</span> Asteris Commerce
    </a>

    <div class="nav-center">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.match) }]}
        >
          {link.label}
        </a>
      ))}

      <div class="nav-dropdown">
        <button
          type="button"
          class="nav-link dropdown-trigger"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Plugins <span class="caret" aria-hidden="true">▾</span>
        </button>
        <div class="dropdown-menu" role="menu">
          {pluginItems.map(p => (
            <a
              href={p.href}
              class="dropdown-item"
              style={`--c: ${p.color};`}
              target="_blank"
              rel="noopener"
              role="menuitem"
            >
              <span class="dd-dot" aria-hidden="true"></span>
              <span class="dd-text">
                <strong>{p.label}</strong>
                <span class="dd-desc">{p.desc}</span>
              </span>
            </a>
          ))}
        </div>
      </div>

      {tailLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: link.match && currentPath.startsWith(link.match) }]}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
  <div class="site-nav-accent" aria-hidden="true"></div>
</div>

<style>
  .site-nav-wrap {
    width: 100%;
    background: var(--c-white);
    position: relative;
    z-index: 100;
  }
  .site-nav-accent {
    height: 6px;
    background: var(--c-violet, #AA00FF);
  }
  .site-nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 22px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .logo {
    font-size: 22px;
    font-weight: 900;
    letter-spacing: -0.5px;
    color: var(--c-black);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    text-decoration: none;
    flex: 0 0 auto;
  }
  .logo .star {
    color: var(--c-violet, #AA00FF);
    font-size: 28px;
    line-height: 1;
  }
  .nav-center {
    display: flex;
    align-items: center;
    gap: 26px;
    flex-wrap: wrap;
    justify-content: flex-end;
    flex: 1 1 auto;
  }
  .nav-link {
    font-size: 16px;
    font-weight: 600;
    color: var(--c-text);
    transition: color 0.1s ease;
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link.active, .dropdown-trigger:focus {
    color: var(--c-violet, #AA00FF);
    outline: none;
  }

  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }
  .dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .caret {
    font-size: 11px;
    margin-top: 2px;
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 340px;
    background: #fff;
    border: 1px solid #e0e3eb;
    border-radius: 14px;
    box-shadow: 0 16px 48px -16px rgba(10, 10, 10, 0.18), 0 4px 12px -4px rgba(10, 10, 10, 0.06);
    padding: 8px;
    display: none;
    flex-direction: column;
    gap: 2px;
    z-index: 200;
  }
  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu {
    display: flex;
  }
  .nav-dropdown:hover .dropdown-trigger,
  .nav-dropdown:focus-within .dropdown-trigger {
    color: var(--c-violet, #AA00FF);
  }
  .nav-dropdown:hover .dropdown-trigger[aria-expanded],
  .nav-dropdown:focus-within .dropdown-trigger[aria-expanded] {
    /* JS-free — aria-expanded stays "false" but visual state is via :hover/:focus-within */
  }
  /* invisible bridge so the menu doesn't close when traversing the gap */
  .nav-dropdown::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 16px;
  }

  .dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--c-text);
    transition: background 0.12s ease;
    border-left: 3px solid transparent;
  }
  .dropdown-item:hover {
    background: #f6f7fa;
    border-left-color: var(--c, var(--c-violet, #AA00FF));
  }
  .dd-dot {
    flex: 0 0 auto;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c, var(--c-violet, #AA00FF));
    margin-top: 5px;
  }
  .dd-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.35;
  }
  .dd-text strong {
    font-size: 16px;
    font-weight: 700;
    color: var(--c-black);
  }
  .dd-desc {
    font-size: 13px;
    color: #6b7280;
    font-weight: 400;
  }

  @media (max-width: 1100px) {
    .site-nav { gap: 16px; }
    .nav-center { gap: 18px; }
    .nav-link { font-size: 15px; }
    .logo { font-size: 20px; }
    .logo .star { font-size: 24px; }
  }
  @media (max-width: 880px) {
    .site-nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      padding: 16px var(--gutter);
    }
    .nav-center {
      width: 100%;
      justify-content: flex-start;
      gap: 14px;
    }
    .dropdown-menu {
      left: 0;
      transform: none;
      min-width: 280px;
    }
  }
</style>
