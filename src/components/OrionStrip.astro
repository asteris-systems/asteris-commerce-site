---
// Orion Web Service cross-sell strip.
// Appears on every parent-site page via Layout.astro (after main, before footer).
// Originally lived on index.astro only — globalised 6 Jun 2026 per Nick's call.
//
// Tracking: UTM-tagged with utm_medium=site-section so we can see in Orion's
// analytics how much traffic Asteris parent site is sending across, and which
// page (if we want to refine later).
---

<section class="orion-section">
  <div class="container">
    <div class="orion-inner">
      <div class="orion-eyebrow">★ Sister business · Orion Web Service</div>
      <h3 class="orion-headline">Need faster hosting, or the team behind Asteris to build your site?</h3>
      <p class="orion-body">
        Orion Web Service runs your WordPress and WooCommerce site on Google Cloud and AWS, fronted by Cloudflare CDN globally. Same Sydney team as Asteris. Building and hosting real client stores since 2021.
      </p>
      <a href="https://orionwebservice.com/?utm_source=asteriscommerce&utm_medium=site-section&utm_campaign=cross-sell" class="orion-cta" target="_blank" rel="noopener">Visit Orion Web Service →</a>
    </div>
  </div>
</section>

<style>
  .orion-section {
    background: var(--c-black);
    color: var(--c-white);
    padding: 72px 0;
    border-top: 4px solid var(--c-orion, #54e0e1);
  }
  .orion-inner {
    /* Full container width — matches everything else on the parent site */
  }
  .orion-eyebrow {
    color: var(--c-orion, #54e0e1);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .orion-headline {
    font-size: 34px;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--c-white);
    margin: 0 0 18px;
  }
  .orion-body {
    font-size: 22px;
    line-height: 1.55;
    color: #cccccc;
    margin: 0 0 28px;
  }
  .orion-body strong { color: var(--c-white); }
  .orion-cta {
    display: inline-block;
    background: var(--c-white);
    color: var(--c-black);
    border: 2px solid var(--c-white);
    padding: 16px 26px;
    font-weight: 700;
    font-size: 18px;
    text-decoration: none;
    border-radius: 8px;
    box-shadow: 4px 4px 0 var(--c-orion, #54e0e1);
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .orion-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--c-orion, #54e0e1);
  }
  @media (max-width: 700px) {
    .orion-headline { font-size: 26px; }
    .orion-body { font-size: 18px; }
  }
</style>
