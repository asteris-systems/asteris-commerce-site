---
// Minimal GDPR/EPR cookie banner — ported from asterisforwoocommerce.com.
// No GA loaded yet (asteriscommerce.com is a brand page, not analytics-heavy),
// so this banner is currently a placeholder for when analytics get wired.
// Strategy when analytics added: defer gtag until window.__asterisConsent === 'accepted'.
---

<aside id="asteris-cookie-banner" class="cb" role="dialog" aria-labelledby="cb-title" aria-describedby="cb-desc" hidden>
  <div class="cb-inner">
    <p id="cb-title" class="cb-title">★ Cookies + tracking</p>
    <p id="cb-desc" class="cb-desc">
      asteriscommerce.com is a static brand site. No third-party analytics, no advertising cookies, no cross-site tracking. We only set a consent-preference cookie if you accept below.
    </p>
    <div class="cb-actions">
      <button type="button" class="cb-btn cb-decline" id="cb-decline">Decline</button>
      <button type="button" class="cb-btn cb-accept" id="cb-accept">Accept</button>
    </div>
  </div>
</aside>

<style>
  .cb {
    position: fixed;
    bottom: 16px;
    right: 16px;
    left: 16px;
    max-width: 460px;
    margin-left: auto;
    background: #1a1a1a;
    color: #f5f5f5;
    border-radius: 10px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    padding: 18px 20px;
    z-index: 9999;
    font-size: 14px;
    line-height: 1.5;
    border-left: 4px solid var(--c-orange, #AA00FF);
  }
  .cb[hidden] { display: none; }
  .cb-title { font-weight: 700; font-size: 14px; margin: 0 0 6px; color: #ffffff; }
  .cb-desc { margin: 0 0 14px; color: #cccccc; }
  .cb-actions { display: flex; gap: 8px; justify-content: flex-end; }
  .cb-btn {
    appearance: none; border: 0; border-radius: 6px;
    padding: 8px 16px; font-size: 13px; font-weight: 600;
    cursor: pointer; font-family: inherit;
  }
  .cb-decline { background: transparent; color: #cccccc; border: 1px solid #444; }
  .cb-decline:hover { background: #2a2a2a; color: #ffffff; }
  .cb-accept { background: var(--c-orange, #AA00FF); color: #000000; }
  .cb-accept:hover { background: #c633ff; }
  @media (max-width: 520px) {
    .cb { bottom: 8px; right: 8px; left: 8px; }
  }
</style>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'asteris-consent';
    var banner = document.getElementById('asteris-cookie-banner');
    if (!banner) return;
    var stored = null;
    try { stored = localStorage.getItem(STORAGE_KEY); } catch (e) {}
    if (stored !== 'accepted' && stored !== 'declined') banner.hidden = false;
    function setConsent(value) {
      try { localStorage.setItem(STORAGE_KEY, value); } catch (e) {}
      banner.hidden = true;
      window.__asterisConsent = value;
      window.dispatchEvent(new CustomEvent('asteris:consent', { detail: { value: value } }));
    }
    document.getElementById('cb-accept').addEventListener('click', function () { setConsent('accepted'); });
    document.getElementById('cb-decline').addEventListener('click', function () { setConsent('declined'); });
    window.__asterisConsent = stored || null;
  })();
</script>
